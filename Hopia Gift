<script>
function claimGift() {
  const name = document.getElementById('nameInput').value.trim();
  const phone = document.getElementById('phoneInput').value.trim();
  if (!name) { alert('Pakisulat ang iyong pangalan.'); return; }
  if (!phone || phone.length < 10) { alert('Pakisulat ang iyong phone number.'); return; }
  document.getElementById('formSection').style.display = 'none';
  document.getElementById('successWrap').style.display = 'block';
  document.getElementById('successName').textContent = name.split(' ')[0];
  document.getElementById('successWrap').scrollIntoView({ behavior: 'smooth', block: 'start' });
  console.log('Lead:', { name, phone, email: document.getElementById('emailInput').value.trim(), time: new Date().toISOString() });
}

let checkedCount = 0;
function toggleCheck(el, id) {
  const box = document.getElementById(id);
  el.classList.toggle('checked');
  if (el.classList.contains('checked')) {
    box.textContent = '☑';
    checkedCount++;
  } else {
    box.textContent = '☐';
    checkedCount--;
  }
  updateResult();
}

function updateResult() {
  const box = document.getElementById('resultBox');
  const title = document.getElementById('resultTitle');
  const msg = document.getElementById('resultMsg');
  if (checkedCount === 0) { box.style.display = 'none'; return; }
  box.style.display = 'block';
  if (checkedCount === 1) {
    title.textContent = 'May isang sign ka — mag-ingat na.';
    msg.textContent = 'Simula pa lang ito. Huwag hintayin pang lumala. Message mo ako para malaman ang solusyon.';
  } else if (checkedCount <= 3) {
    title.textContent = checkedCount + ' signs — kailangan mo na ng tulong.';
    msg.textContent = 'Hindi ito normal. Ang katawan mo ay nagbibigay ng signal. Message mo ako sa Facebook — libre ang usap.';
  } else {
    title.textContent = checkedCount + ' signs — urgent na ito.';
    msg.textContent = 'Marami ka nang naramdaman. Huwag palampasin ito. Message mo ako ngayon para tulungan kita.';
  }
}
</script>

